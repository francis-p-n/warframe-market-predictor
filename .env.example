# ─── Twilio WhatsApp ───────────────────────────────────────────────────────────
# Sign up free at https://twilio.com, then go to Console > Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Sandbox number (use this exact value for sandbox mode):
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Your personal WhatsApp number in international format (no spaces):
# Example: whatsapp:+601XXXXXXXXX  for Malaysia
#          whatsapp:+1XXXXXXXXXX   for USA
WHATSAPP_TO=whatsapp:+60XXXXXXXXXX

# ─── Schedule ──────────────────────────────────────────────────────────────────
# Time to send the daily report (24h HH:MM, local time)
REPORT_TIME=09:00

# How often to fetch fresh price data (in hours)
FETCH_INTERVAL_HOURS=4

# ─── Item Tracking ─────────────────────────────────────────────────────────────
# Number of top-volume items to auto-track (in addition to your watchlist)
TOP_ITEMS_COUNT=50

# Skip items with fewer than this many trades per day (illiquid items are noisy)
MIN_VOLUME_FILTER=5

# ─── Report Settings ───────────────────────────────────────────────────────────
# Max items per section in the daily report (BUY / SELL / HOLD)
MAX_ITEMS_PER_SECTION=5

# Minimum confidence score (0.0–1.0) to include a signal in the report
MIN_SIGNAL_CONFIDENCE=0.55
