# ─── ntfy.sh (free, no account needed) ────────────────────────────────────────
#
# 1. Install the ntfy app:
#    Android: https://play.google.com/store/apps/details?id=io.heckel.ntfy
#    iOS:     https://apps.apple.com/app/ntfy/id1625396347
#
# 2. Pick a secret topic name — like a password, hard to guess.
#    e.g. warframe-predictor-k9x2mq7p
#
# 3. In the ntfy app, tap "+" and subscribe to your topic name.
#    Done! You'll now receive push notifications.
#
# To share with friends: they install ntfy, subscribe to the same topic name.
# No accounts, no sign-up, completely free forever.

NTFY_TOPIC=warframe-predictor-changeme

# Optional: self-host ntfy for full privacy (https://docs.ntfy.sh/install/)
# Leave blank to use the free public server.
# NTFY_SERVER=https://ntfy.sh

# ─── Schedule ──────────────────────────────────────────────────────────────────
# Time to send the daily report (24h HH:MM, local time)
REPORT_TIME=09:00

# How often to fetch fresh price data (in hours)
FETCH_INTERVAL_HOURS=4

# ─── Item Tracking ─────────────────────────────────────────────────────────────
# Number of top-volume items to auto-track (in addition to your watchlist)
TOP_ITEMS_COUNT=50

# Skip items with fewer than this many trades per day (illiquid items are noisy)
MIN_VOLUME_FILTER=5

# ─── Report Settings ───────────────────────────────────────────────────────────
# Max items per section in the daily report (BUY / SELL / HOLD)
MAX_ITEMS_PER_SECTION=5

# Minimum confidence score (0.0–1.0) to include a signal in the report
MIN_SIGNAL_CONFIDENCE=0.55
