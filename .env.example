# ─── Discord Webhook ───────────────────────────────────────────────────────────
#
# How to get a webhook URL (takes ~30 seconds):
#   1. Open Discord → your server → pick a channel
#   2. Edit Channel → Integrations → Webhooks → New Webhook
#   3. Click "Copy Webhook URL" and paste it below
#
# For 2 people: both of you join the same Discord server/channel.
# The bot will post there and you'll both see it instantly.
#
# Multiple channels: separate URLs with commas.
# Example (two channels): https://discord.com/.../webhooks/AAA,https://discord.com/.../webhooks/BBB

DISCORD_WEBHOOK_URLS=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL_HERE

# ─── Schedule ──────────────────────────────────────────────────────────────────
REPORT_TIME=09:00
FETCH_INTERVAL_HOURS=4

# ─── Item Tracking ─────────────────────────────────────────────────────────────
TOP_ITEMS_COUNT=50
MIN_VOLUME_FILTER=5

# ─── Report Settings ───────────────────────────────────────────────────────────
# How many items to show per section (up to 10)
MAX_ITEMS_PER_SECTION=10

# How confident the model needs to be before including a signal (0.0-1.0)
# Lower = more signals but noisier. Higher = fewer but more reliable.
MIN_SIGNAL_CONFIDENCE=0.55
